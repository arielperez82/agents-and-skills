{
  "name": "context-management",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Context window monitoring and handoff enforcement hooks for Claude Code",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "test": "bash test.sh",
    "lint:sh": "sh ../../scripts/run-shellcheck.sh scripts/*.sh install.sh",
    "lint:sh:fix": "sh ../../scripts/run-shellcheck.sh --fix scripts/*.sh install.sh",
    "validate": "concurrently 'pnpm test' 'pnpm lint:sh'"
  }
}
