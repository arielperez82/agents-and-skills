{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/commit-gate-pre.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/commit-nudge-post.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm -f /tmp/claude-commit-risk-${CLAUDE_CODE_SSE_PORT:-global} /tmp/claude-commit-nudged-${CLAUDE_CODE_SSE_PORT:-global}"
          }
        ]
      }
    ]
  }
}
